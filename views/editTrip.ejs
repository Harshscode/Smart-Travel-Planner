<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Smart Travel Planner</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="form-page-body">

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/dashboard" class="nav-brand">
                <i class="fas fa-plane-departure"></i> Smart Travel Planner
            </a>
            <div class="nav-menu">
                <a href="/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/add-trip" class="nav-link">
                    <i class="fas fa-plus-circle"></i> Add Trip
                </a>
            </div>
            <div class="nav-user">
                <span class="user-welcome">
                    <i class="fas fa-user-circle"></i> <%= user.username %>
                </span>
                <a href="/logout" class="btn btn-outline btn-sm">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content form-page">
        <div class="form-container">

            <div class="form-header">
                <a href="/dashboard" class="back-link">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
                <h1><i class="fas fa-edit"></i> Edit Trip</h1>
                <p class="page-subtitle">Update the details for your trip to <strong><%= trip.destination %></strong>.</p>
            </div>

            <!-- Error Alert -->
            <% if (error) { %>
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
            <% } %>

            <form action="/edit-trip/<%= trip.id %>" method="POST" class="trip-form" id="tripForm">

                <!-- Destination -->
                <div class="form-group">
                    <label for="destination">
                        <i class="fas fa-map-marker-alt"></i> Destination
                    </label>
                    <input
                        type="text"
                        id="destination"
                        name="destination"
                        value="<%= trip.destination %>"
                        placeholder="e.g., Paris, France"
                        required
                    >
                    <small class="form-hint">Enter the city or city and country</small>
                </div>

                <!-- Dates Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="startDate">
                            <i class="fas fa-calendar-check"></i> Start Date
                        </label>
                        <input
                            type="date"
                            id="startDate"
                            name="startDate"
                            value="<%= trip.startDate %>"
                            required
                        >
                    </div>
                    <div class="form-group">
                        <label for="endDate">
                            <i class="fas fa-calendar-times"></i> End Date
                        </label>
                        <input
                            type="date"
                            id="endDate"
                            name="endDate"
                            value="<%= trip.endDate %>"
                            required
                        >
                    </div>
                </div>

                <!-- Budget Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="budget">
                            <i class="fas fa-coins"></i> Budget
                        </label>
                        <input
                            type="number"
                            id="budget"
                            name="budget"
                            value="<%= trip.budget %>"
                            min="0"
                            step="0.01"
                        >
                    </div>
                    <div class="form-group">
                        <label for="currency">
                            <i class="fas fa-money-bill-wave"></i> Currency
                        </label>
                        <select id="currency" name="currency">
                            <% const currencies = [
                                ['USD','US Dollar'],['EUR','Euro'],['GBP','British Pound'],
                                ['JPY','Japanese Yen'],['CAD','Canadian Dollar'],['AUD','Australian Dollar'],
                                ['CHF','Swiss Franc'],['CNY','Chinese Yuan'],['INR','Indian Rupee'],
                                ['MXN','Mexican Peso'],['BRL','Brazilian Real'],['KRW','Korean Won'],
                                ['SGD','Singapore Dollar'],['THB','Thai Baht'],['ZAR','South African Rand']
                            ]; %>
                            <% currencies.forEach(function(c) { %>
                                <option value="<%= c[0] %>" <%= trip.currency === c[0] ? 'selected' : '' %>>
                                    <%= c[0] %> — <%= c[1] %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <!-- Notes -->
                <div class="form-group">
                    <label for="notes">
                        <i class="fas fa-sticky-note"></i> Notes <span class="optional">(optional)</span>
                    </label>
                    <textarea
                        id="notes"
                        name="notes"
                        rows="4"
                        placeholder="Any additional notes about your trip..."
                    ><%= trip.notes || '' %></textarea>
                </div>

                <!-- Submit -->
                <div class="form-actions">
                    <a href="/dashboard" class="btn btn-outline">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>

        </div>
    </main>

    <script>
        // If start date is set, update end date minimum
        document.getElementById('startDate').addEventListener('change', function() {
            document.getElementById('endDate').setAttribute('min', this.value);
        });

        document.getElementById('tripForm').addEventListener('submit', function(e) {
            const start = document.getElementById('startDate').value;
            const end = document.getElementById('endDate').value;

            if (start && end && new Date(end) < new Date(start)) {
                e.preventDefault();
                alert('End date must be the same as or after the start date.');
            }
        });
    </script>

</body>
</html>
